# =============================================================================
# PAGINACABEXUDOS - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
# For local development:
#   cp .env.example .env
#   # Edit .env with your values
# =============================================================================

# =============================================================================
# Frontend (Vite)
# =============================================================================

# WebSocket URL of the GPS Relay Server.
# When using the integrated server (server.js), leave empty to use same origin.
# For local development: leave empty (uses same origin)
# For production: leave empty (uses same origin)
# VITE_WS_RELAY_URL=

# =============================================================================
# GPS Relay Server
# =============================================================================

# Port for the server (default: 3001, Render uses $PORT)
PORT=3001

# Log level: debug | info | warn | error
LOG_LEVEL=info

# CORS origin for the health endpoint (default: *)
CORS_ORIGIN=*

# Room cleanup interval in ms (default: 60000 = 1 minute)
CLEANUP_INTERVAL=60000

# Room idle TTL before cleanup in ms (default: 300000 = 5 minutes)
ROOM_IDLE_TTL=300000

# Authorized GPS devices (JSON format)
# Example: {"cmp_prueba_barrio": true, "anotherToken": true}
# AUTHORIZED_GPS_DEVICES={"cmp_prueba_barrio": true}
