# =============================================================================
# PAGINACABEXUDOS - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#
# For local development:
#   cp .env.example .env
#   # Edit .env with your values
# =============================================================================

# =============================================================================
# Frontend (Vite)
# =============================================================================

# WebSocket URL of the GPS Relay Server.
# For local development: ws://localhost:3001
# For production: ws://YOUR_SERVER_IP:3001
# If connecting from a phone via 4G/5G, use your server's PUBLIC IP address.
# If you have a domain: wss://gps.paginacabexudos.com (requires SSL)
VITE_WS_RELAY_URL=ws://localhost:3001

# Optional: specific WebSocket URL for the Recorridos page GPS mode
VITE_WS_URL=ws://localhost:3001

# =============================================================================
# GPS Relay Server
# =============================================================================

# Port for the WebSocket server (default: 3001)
GPS_RELAY_PORT=3001

# Log level: debug | info | warn | error
GPS_RELAY_LOG_LEVEL=info

# CORS origin for the health endpoint (default: *)
CORS_ORIGIN=*

# Room cleanup interval in ms (default: 60000 = 1 minute)
CLEANUP_INTERVAL=60000

# Room idle TTL before cleanup in ms (default: 300000 = 5 minutes)
ROOM_IDLE_TTL=300000