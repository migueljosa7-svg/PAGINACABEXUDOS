# =============================================================================
# PAGINACABEXUDOS - Environment Variables (Local Development)
# =============================================================================

# WebSocket URL of the GPS Relay Server.
# For local development, leave empty to use same origin.
# VITE_WS_RELAY_URL=

# GPS Relay Server Configuration
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=*
CLEANUP_INTERVAL=60000
ROOM_IDLE_TTL=300000

# Authorized GPS devices (JSON format)
# This is the token used for the "Prueba Barrio" demo
AUTHORIZED_GPS_DEVICES={"cmp_prueba_barrio": true}